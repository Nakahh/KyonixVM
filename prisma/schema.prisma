// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Use SQLite for development, PostgreSQL for production
  // Set DATABASE_URL to file:./dev.db for SQLite or postgresql://... for PostgreSQL
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Strategy configuration for provisioning
model Strategy {
  id                String   @id @default(cuid())
  name              String
  description       String?
  status            String   @default("draft") // draft, active, paused, completed
  imageType         String   // OS image identifier
  shape             String   // VM shape/type
  concurrencyLimit  Int      @default(5)
  maxRetries        Int      @default(3)
  targetInstances   Int      @default(10)
  timeoutSeconds    Int      @default(300)
  retryIntervalSecs Int      @default(20)
  
  // Relations
  targets           Target[]
  instances         Instance[]
  attempts          Attempt[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([status])
  @@index([createdAt])
}

// Provisioning targets (regions, ADs, subnets)
model Target {
  id                    String   @id @default(cuid())
  strategyId            String
  strategy              Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  
  region                String
  availabilityDomain    String
  subnet                String
  priority              Int      @default(0)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  attempts              Attempt[]
  
  @@index([strategyId])
  @@index([region])
}

// Created VM instances
model Instance {
  id          String   @id @default(cuid())
  ociId       String?  @unique // OCI-assigned instance ID
  name        String   @unique
  region      String
  status      String   @default("pending") // pending, creating, running, failed, terminated
  strategyId  String
  strategy    Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  
  // Idempotency
  requestId   String   @unique // opc-request-id from OCI
  retryToken  String?  // opc-retry-token for idempotency
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([strategyId])
  @@index([status])
  @@index([region])
  @@index([createdAt])
}

// Provisioning attempts (each try to create an instance)
model Attempt {
  id             String   @id @default(cuid())
  strategyId     String
  strategy       Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  
  targetId       String
  target         Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
  
  status         String   @default("pending") // pending, in_progress, success, error
  errorMessage   String?
  requestId      String   @unique // OCI request ID for tracking
  retryCount     Int      @default(0)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@index([strategyId])
  @@index([targetId])
  @@index([status])
  @@index([createdAt])
}

// Audit logs
model Log {
  id        String   @id @default(cuid())
  level     String   @default("info") // debug, info, warn, error
  message   String
  metadata  Json?
  timestamp DateTime @default(now())
  
  @@index([level])
  @@index([timestamp])
}

// Scheduler state (tracking cycle execution)
model SchedulerState {
  id                String   @id @default("scheduler")
  lastCycleAt       DateTime?
  nextCycleAt       DateTime?
  isRunning         Boolean  @default(false)
  currentCycleCount Int      @default(0)
  updatedAt         DateTime @updatedAt
}
