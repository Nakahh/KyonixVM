# OCI Auto Provisioner Environment Variables

# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/oci_auto_provisioner

# Redis (for queue management)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OCI Configuration
OCI_TENANCY_OCID=ocid1.tenancy.oc1..
OCI_USER_OCID=ocid1.user.oc1..
OCI_FINGERPRINT=
OCI_PRIVATE_KEY_PATH=/path/to/private/key
OCI_REGION=us-phoenix-1

# Scheduler Configuration
SCHEDULER_INTERVAL_SECONDS=20
SCHEDULER_ENABLED=true

# Worker Configuration
WORKER_ENABLED=true
WORKER_INTERVAL_SECONDS=5
WORKER_CONCURRENCY=10

# Logging
LOG_LEVEL=info

# Monitoring
METRICS_ENABLED=true
METRICS_INTERVAL_SECONDS=60

# Security
API_KEY=
JWT_SECRET=
