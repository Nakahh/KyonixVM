# Development Environment Variables
# NOTE: For production, use proper credentials and run migrations

# Application
NODE_ENV=development
PORT=3000

# Database (SQLite for development - change to PostgreSQL for production)
# For PostgreSQL: postgresql://user:password@localhost:5432/oci_auto_provisioner
DATABASE_URL=file:./dev.db

# Redis (optional for development)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OCI Configuration (optional - uses simulation mode if not configured)
OCI_TENANCY_OCID=ocid1.tenancy.oc1.simulation
OCI_USER_OCID=ocid1.user.oc1.simulation
OCI_FINGERPRINT=00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00
OCI_PRIVATE_KEY_PATH=/path/to/key
OCI_REGION=us-phoenix-1

# Scheduler & Worker
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=20
WORKER_ENABLED=true
WORKER_INTERVAL_SECONDS=5

# Builder.io (Vite)
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__
PING_MESSAGE="ping pong"
